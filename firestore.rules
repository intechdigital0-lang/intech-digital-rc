rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny everything
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == "intechdigital0@gmail.com" || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Collections ---

    match /admins/{adminId} {
      allow get: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    match /portfolio/{itemId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin() && isValidId(itemId);
    }

    match /settings/{settingId} {
      allow get, list: if true;
      allow write: if isAdmin() && isValidId(settingId);
    }

    match /testimonials/{testimonialId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin() && isValidId(testimonialId);
    }
  }
}
